NODE_ENV=development
PORT=3000

# Dominio del frontend/panel permitido (CORS)
APP_ORIGIN=http://localhost:5173

# Cookie/session
COOKIE_NAME=mrx_session
COOKIE_SECURE=false
SESSION_TTL_DAYS=14

# Telegram bot
TELEGRAM_BOT_TOKEN=PASTE_YOUR_TOKEN

# Prisma DB (dev: SQLite)
DATABASE_URL="file:./dev.db"
